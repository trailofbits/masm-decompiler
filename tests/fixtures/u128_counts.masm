pub proc clz(a: u128) -> u8
    movup.3
    dup.0
    eq.0

    if.true
        drop
        movup.2
        dup.0
        eq.0

        if.true
            drop
            swap
            dup.0
            eq.0

            if.true
                drop
                u32clz
                add.96
            else
                swap drop
                u32clz
                add.64
            end
        else
            movdn.2 drop drop
            u32clz
            add.32
        end
    else
        movdn.3 drop drop drop
        u32clz
    end
end

